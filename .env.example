# ─── Required API Keys ────────────────────────────────────────────────────────

# Hugging Face API token — used for embeddings (all-MiniLM-L6-v2 via HF Inference API)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your-token-here

# Google Gemini API key — used for answer generation
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Chunking ─────────────────────────────────────────────────────────────────

# Maximum tokens per chunk (default: 300)
CHUNK_SIZE_TOKENS=300

# Token overlap between consecutive chunks on the same page (default: 50)
CHUNK_OVERLAP_TOKENS=50

# ─── Retrieval ────────────────────────────────────────────────────────────────

# Number of candidates retrieved from vector search AND BM25 independently (default: 10)
RETRIEVAL_TOP_K=10

# ─── Reranker (optional) ──────────────────────────────────────────────────────

# Enable cross-encoder reranking (cross-encoder/ms-marco-MiniLM-L-6-v2)
# Requires sentence-transformers. Downloads ~85MB model on first use.
# Default: false
ENABLE_RERANKER=false

# Number of chunks to keep after reranking (default: 5)
RERANK_TOP_N=5

# ─── Refusal Thresholds ───────────────────────────────────────────────────────

# Minimum vector similarity score (0–1 cosine) to answer; below this → refusal
# Default: 0.30
MIN_RETRIEVAL_SCORE=0.30

# Minimum number of retrieved chunks required to attempt an answer
# Default: 2
MIN_CHUNKS_REQUIRED=2

# ─── Generation ───────────────────────────────────────────────────────────────

# Gemini model to use for answer generation
# Default: gemini-3.1-flash-lite
GENERATION_MODEL=gemini-3.1-flash-lite

# ─── Vector Store (optional) ──────────────────────────────────────────────────

# Qdrant storage mode: "memory" (default, clean slate per restart) or "disk"
QDRANT_MODE=memory

# Path for disk-mode Qdrant storage (only used when QDRANT_MODE=disk)
QDRANT_PATH=./qdrant_data
